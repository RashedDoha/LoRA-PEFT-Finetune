   "metadata": {},
   "outputs": [],
   "source": [
    "class WandbDetailedCallback(TrainerCallback):\n",
    "    \"\"\"Logs additional metrics that SFTTrainer doesn't log by default.\"\"\"\n",
    "\n",
    "    def on_log(self, args, state, control, logs=None, **kwargs):\n",
    "        if logs:\n",
    "            # Log gradient norm if available\n",
    "            if \"grad_norm\" in logs:\n",
    "                wandb.log({\"train/grad_norm\": logs[\"grad_norm\"]},\n",
    "                          step=state.global_step)\n",
    "\n",
    "            # Log learning rate\n",
    "            if \"learning_rate\" in logs:\n",
    "                wandb.log({\"train/learning_rate\": logs[\"learning_rate\"]},\n",
    "                          step=state.global_step)\n",
    "\n",
    "    def on_epoch_end(self, args, state, control, **kwargs):\n",
    "        wandb.log({\"train/epoch\": state.epoch}, step=state.global_step)\n",
    "\n",
    "    def on_train_end(self, args, state, control, **kwargs):\n",
    "        wandb.log({\n",
    "            \"train/final_loss\":        state.log_history[-1].get(\"loss\", None),\n",
    "            \"train/total_steps\":       state.global_step,\n",
    "            \"train/total_flos\":        state.total_flos,\n",
    "        })"
   ]
  },
